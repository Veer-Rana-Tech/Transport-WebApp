<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>E-K Transport - Admin Dashboard</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --primary: #4361ee;
            --primary-dark: #3a56d4;
            --secondary: #7209b7;
            --success: #4cc9f0;
            --warning: #f72585;
            --danger: #e63946;
            --light: #f8f9fa;
            --dark: #212529;
            --gray: #6c757d;
            --light-gray: #e9ecef;
            --border-radius: 8px;
            --box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f5f7fb;
            color: var(--dark);
            line-height: 1.6;
        }

        .admin-container {
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar Styles */
        .sidebar {
            width: 250px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            padding: 20px 0;
            transition: var(--transition);
            box-shadow: var(--box-shadow);
            z-index: 100;
        }

        .logo {
            display: flex;
            align-items: center;
            padding: 0 20px 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            margin-bottom: 20px;
        }

        .logo i {
            font-size: 24px;
            margin-right: 10px;
        }

        .logo h1 {
            font-size: 20px;
            font-weight: 600;
        }

        .nav-links {
            list-style: none;
            padding: 0 15px;
        }

        .nav-links li {
            margin-bottom: 5px;
        }

        .nav-links a {
            display: flex;
            align-items: center;
            padding: 12px 15px;
            color: rgba(255, 255, 255, 0.8);
            text-decoration: none;
            border-radius: var(--border-radius);
            transition: var(--transition);
        }

        .nav-links a:hover,
        .nav-links a.active {
            background-color: rgba(255, 255, 255, 0.1);
            color: white;
        }

        .nav-links i {
            margin-right: 10px;
            font-size: 18px;
            width: 24px;
            text-align: center;
        }

        /* Main Content Styles */
        .main-content {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding-bottom: 15px;
            border-bottom: 1px solid var(--light-gray);
        }

        .header h2 {
            font-weight: 600;
            color: var(--dark);
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background-color: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 600;
        }

        /* Stats Cards */
        .stats-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: white;
            border-radius: var(--border-radius);
            padding: 20px;
            box-shadow: var(--box-shadow);
            transition: var(--transition);
        }

        .stat-card:hover {
            transform: translateY(-5px);
        }

        .stat-card i {
            font-size: 24px;
            margin-bottom: 10px;
            padding: 10px;
            border-radius: 50%;
            width: 45px;
            height: 45px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .stat-card.submitted i {
            background-color: rgba(67, 97, 238, 0.1);
            color: var(--primary);
        }

        .stat-card.verified i {
            background-color: rgba(76, 201, 240, 0.1);
            color: var(--success);
        }

        .stat-card.background i {
            background-color: rgba(247, 37, 133, 0.1);
            color: var(--warning);
        }

        .stat-card.approved i {
            background-color: rgba(56, 176, 0, 0.1);
            color: #38b000;
        }

        .stat-card h3 {
            font-size: 24px;
            font-weight: 600;
            margin-bottom: 5px;
        }

        .stat-card p {
            color: var(--gray);
            font-size: 14px;
        }

        /* Applications Table */
        .applications-section {
            background: white;
            border-radius: var(--border-radius);
            box-shadow: var(--box-shadow);
            overflow: hidden;
            margin-bottom: 30px;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px;
            border-bottom: 1px solid var(--light-gray);
        }

        .section-header h3 {
            font-weight: 600;
        }

        .filters {
            display: flex;
            gap: 10px;
        }

        .filter-select {
            padding: 8px 12px;
            border: 1px solid var(--light-gray);
            border-radius: var(--border-radius);
            background: white;
            font-family: 'Poppins', sans-serif;
        }

        .table-container {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th,
        td {
            padding: 15px;
            text-align: left;
            border-bottom: 1px solid var(--light-gray);
        }

        th {
            font-weight: 500;
            color: var(--gray);
            font-size: 14px;
        }

        .status-badge {
            display: inline-block;
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }

        .status-submitted {
            background-color: rgba(67, 97, 238, 0.1);
            color: var(--primary);
        }

        .status-verified {
            background-color: rgba(76, 201, 240, 0.1);
            color: var(--success);
        }

        .status-background {
            background-color: rgba(247, 37, 133, 0.1);
            color: var(--warning);
        }

        .status-approved {
            background-color: rgba(56, 176, 0, 0.1);
            color: #38b000;
        }

        .status-rejected {
            background-color: rgba(230, 57, 70, 0.1);
            color: var(--danger);
        }

        .action-btn {
            padding: 6px 12px;
            border: none;
            border-radius: var(--border-radius);
            background: var(--primary);
            color: white;
            font-family: 'Poppins', sans-serif;
            cursor: pointer;
            transition: var(--transition);
            font-size: 12px;
        }

        .action-btn:hover {
            background: var(--primary-dark);
        }

        /* Application Details Modal */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(0, 0, 0, 0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            padding: 20px;
            opacity: 0;
            visibility: hidden;
            transition: var(--transition);
        }

        .modal-overlay.active {
            opacity: 1;
            visibility: visible;
        }

        .modal {
            background: white;
            border-radius: var(--border-radius);
            width: 100%;
            max-width: 900px;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            transform: translateY(-20px);
            transition: var(--transition);
        }

        .modal-overlay.active .modal {
            transform: translateY(0);
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px;
            border-bottom: 1px solid var(--light-gray);
        }

        .modal-header h3 {
            font-weight: 600;
        }

        .close-modal {
            background: none;
            border: none;
            font-size: 20px;
            cursor: pointer;
            color: var(--gray);
        }

        .modal-body {
            padding: 20px;
        }

        .tabs {
            display: flex;
            border-bottom: 1px solid var(--light-gray);
            margin-bottom: 20px;
        }

        .tab {
            padding: 12px 20px;
            background: none;
            border: none;
            font-family: 'Poppins', sans-serif;
            cursor: pointer;
            transition: var(--transition);
            border-bottom: 2px solid transparent;
        }

        .tab.active {
            border-bottom: 2px solid var(--primary);
            color: var(--primary);
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 20px;
        }

        .info-item {
            margin-bottom: 15px;
        }

        .info-label {
            font-size: 12px;
            color: var(--gray);
            margin-bottom: 5px;
        }

        .info-value {
            font-weight: 500;
        }

        .documents-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
            gap: 20px;
        }

        .document-card {
            border: 1px solid var(--light-gray);
            border-radius: var(--border-radius);
            overflow: hidden;
            transition: var(--transition);
        }

        .document-card:hover {
            box-shadow: var(--box-shadow);
        }

        .document-preview {
            height: 150px;
            background-color: var(--light-gray);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 40px;
            color: var(--gray);
            overflow: hidden;
            position: relative;
        }

        .document-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: none;
        }

        .document-preview.has-image .fa {
            display: none;
        }

        .document-preview.has-image img {
            display: block;
        }

        .document-loading {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 14px;
            color: var(--gray);
        }

        .document-info {
            padding: 15px;
        }

        .document-name {
            font-weight: 500;
            margin-bottom: 5px;
        }

        .document-actions {
            display: flex;
            gap: 10px;
            margin-top: 10px;
        }

        .btn {
            padding: 8px 15px;
            border: none;
            border-radius: var(--border-radius);
            font-family: 'Poppins', sans-serif;
            cursor: pointer;
            transition: var(--transition);
            font-size: 12px;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        .btn-primary {
            background: var(--primary);
            color: white;
        }

        .btn-primary:hover {
            background: var(--primary-dark);
        }

        .btn-outline {
            background: transparent;
            border: 1px solid var(--primary);
            color: var(--primary);
        }

        .btn-outline:hover {
            background: var(--primary);
            color: white;
        }

        .status-update-form {
            background: var(--light);
            padding: 20px;
            border-radius: var(--border-radius);
            margin-top: 20px;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            font-weight: 500;
        }

        .form-control {
            width: 100%;
            padding: 10px;
            border: 1px solid var(--light-gray);
            border-radius: var(--border-radius);
            font-family: 'Poppins', sans-serif;
        }

        textarea.form-control {
            min-height: 100px;
            resize: vertical;
        }

        .status-history {
            margin-top: 30px;
        }

        .status-timeline {
            position: relative;
            padding-left: 30px;
        }

        .status-timeline::before {
            content: '';
            position: absolute;
            left: 10px;
            top: 0;
            bottom: 0;
            width: 2px;
            background: var(--light-gray);
        }

        .status-item {
            position: relative;
            margin-bottom: 20px;
        }

        .status-item::before {
            content: '';
            position: absolute;
            left: -20px;
            top: 5px;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: var(--primary);
        }

        .status-item.completed::before {
            background: var(--success);
        }

        .status-item.rejected::before {
            background: var(--danger);
        }

        .status-date {
            font-size: 12px;
            color: var(--gray);
        }

        .status-notes {
            margin-top: 5px;
            font-size: 14px;
        }

        /* Loading Spinner */
        .loading-spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255, 255, 255, .3);
            border-radius: 50%;
            border-top-color: #fff;
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* Alert Styles */
        .alert {
            padding: 12px 15px;
            border-radius: var(--border-radius);
            margin-bottom: 20px;
            font-size: 14px;
            display: none;
        }

        .alert-error {
            background: rgba(230, 57, 70, 0.1);
            border: 1px solid var(--danger);
            color: #721c24;
        }

        /* Responsive Styles */
        @media (max-width: 992px) {
            .admin-container {
                flex-direction: column;
            }

            .sidebar {
                width: 100%;
                height: auto;
            }

            .nav-links {
                display: flex;
                overflow-x: auto;
                padding-bottom: 10px;
            }

            .nav-links li {
                margin-bottom: 0;
                margin-right: 10px;
            }

            .nav-links a {
                white-space: nowrap;
            }
        }

        @media (max-width: 768px) {
            .stats-container {
                grid-template-columns: 1fr 1fr;
            }

            .info-grid {
                grid-template-columns: 1fr;
            }

            .documents-grid {
                grid-template-columns: 1fr;
            }

            .header {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }

            .user-info {
                align-self: flex-end;
            }
        }

        @media (max-width: 576px) {
            .stats-container {
                grid-template-columns: 1fr;
            }

            .filters {
                flex-direction: column;
            }

            .table-container {
                font-size: 14px;
            }

            th,
            td {
                padding: 10px 5px;
            }
        }
    </style>
</head>

<body>
    <div class="admin-container">
        <!-- Sidebar -->
        <div class="sidebar">
            <div class="logo">
                <i class="fas fa-truck"></i>
                <h1>E-K Transport</h1>
            </div>
            <ul class="nav-links">
                <li><a href="#" class="active"><i class="fas fa-home"></i> Dashboard</a></li>
                <li><a href="#"><i class="fas fa-users"></i> Applications</a></li>
                <li><a href="#"><i class="fas fa-cog"></i> Settings</a></li>
                <li><a href="#" id="logoutBtn"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
            </ul>
        </div>

        <!-- Main Content -->
        <div class="main-content">
            <div class="header">
                <h2>Driver Applications Dashboard</h2>
                <div class="user-info">
                    <div class="user-avatar" id="userAvatar">AD</div>
                    <span id="userName">Loading...</span>
                </div>
            </div>

            <!-- Alert Messages -->
            <div class="alert alert-error" id="errorAlert">
                <i class="fas fa-exclamation-circle"></i> <span id="errorMessage"></span>
            </div>

            <!-- Stats Cards -->
            <div class="stats-container" id="statsContainer">
                <div class="stat-card submitted">
                    <i class="fas fa-file-alt"></i>
                    <h3 id="submittedCount">0</h3>
                    <p>Submitted Applications</p>
                </div>
                <div class="stat-card verified">
                    <i class="fas fa-check-circle"></i>
                    <h3 id="verifiedCount">0</h3>
                    <p>Documents Verified</p>
                </div>
                <div class="stat-card background">
                    <i class="fas fa-search"></i>
                    <h3 id="backgroundCount">0</h3>
                    <p>Background Checks</p>
                </div>
                <div class="stat-card approved">
                    <i class="fas fa-user-check"></i>
                    <h3 id="approvedCount">0</h3>
                    <p>Approved Drivers</p>
                </div>
            </div>

            <!-- Applications Table -->
            <div class="applications-section">
                <div class="section-header">
                    <h3>Recent Applications</h3>
                    <div class="filters">
                        <select class="filter-select" id="statusFilter">
                            <option value="">All Status</option>
                            <option value="submitted">Submitted</option>
                            <option value="document_verified">Document Verified</option>
                            <option value="background_check">Background Check</option>
                            <option value="approved">Approved</option>
                            <option value="rejected">Rejected</option>
                        </select>
                        <select class="filter-select" id="sortFilter">
                            <option value="created_at">Sort by Date</option>
                            <option value="full_name">Sort by Name</option>
                            <option value="status">Sort by Status</option>
                        </select>
                    </div>
                </div>
                <div class="table-container">
                    <table id="applicationsTable">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Experience</th>
                                <th>License Type</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="applicationsTableBody">
                            <tr>
                                <td colspan="8" style="text-align: center; padding: 40px;">
                                    <div class="loading-spinner"></div>
                                    <p>Loading applications...</p>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Application Details Modal -->
    <div class="modal-overlay" id="applicationModal">
        <div class="modal">
            <div class="modal-header">
                <h3>Application Details - <span id="modal-app-id">ET20241001</span></h3>
                <button class="close-modal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="tabs">
                    <button class="tab active" data-tab="personal">Personal Info</button>
                    <button class="tab" data-tab="documents">Documents</button>
                    <button class="tab" data-tab="status">Status Update</button>
                    <button class="tab" data-tab="history">Status History</button>
                </div>

                <!-- Personal Info Tab -->
                <div class="tab-content active" id="personal-tab">
                    <div class="info-grid">
                        <div class="info-item">
                            <div class="info-label">Full Name</div>
                            <div class="info-value" id="detail-name">Loading...</div>
                        </div>
                        <div class="info-item">
                            <div class="info-label">Email</div>
                            <div class="info-value" id="detail-email">Loading...</div>
                        </div>
                        <div class="info-item">
                            <div class="info-label">Phone</div>
                            <div class="info-value" id="detail-phone">Loading...</div>
                        </div>
                        <div class="info-item">
                            <div class="info-label">Date of Birth</div>
                            <div class="info-value" id="detail-dob">Loading...</div>
                        </div>
                        <div class="info-item">
                            <div class="info-label">Address</div>
                            <div class="info-value" id="detail-address">Loading...</div>
                        </div>
                        <div class="info-item">
                            <div class="info-label">Driving Experience</div>
                            <div class="info-value" id="detail-experience">Loading...</div>
                        </div>
                        <div class="info-item">
                            <div class="info-label">License Type</div>
                            <div class="info-value" id="detail-license">Loading...</div>
                        </div>
                        <div class="info-item">
                            <div class="info-label">Vehicle Type</div>
                            <div class="info-value" id="detail-vehicle">Loading...</div>
                        </div>
                        <div class="info-item">
                            <div class="info-label">Availability</div>
                            <div class="info-value" id="detail-availability">Loading...</div>
                        </div>
                        <div class="info-item">
                            <div class="info-label">Preferred Locations</div>
                            <div class="info-value" id="detail-locations">Loading...</div>
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Additional Information</div>
                        <div class="info-value" id="detail-additional">Loading...</div>
                    </div>
                </div>

                <!-- Documents Tab -->
                <div class="tab-content" id="documents-tab">
                    <div class="documents-grid" id="documentsGrid">
                        <!-- Documents will be loaded here -->
                    </div>
                </div>

                <!-- Status Update Tab -->
                <div class="tab-content" id="status-tab">
                    <div class="status-update-form">
                        <div class="form-group">
                            <label for="status-select">Update Status</label>
                            <select class="form-control" id="status-select">
                                <option value="submitted">Submitted</option>
                                <option value="document_verified">Document Verified</option>
                                <option value="background_check">Background Check</option>
                                <option value="interview_scheduled">Interview Scheduled</option>
                                <option value="approved">Approved</option>
                                <option value="rejected">Rejected</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="status-notes">Notes</label>
                            <textarea class="form-control" id="status-notes"
                                placeholder="Add any notes about this status update..."></textarea>
                        </div>
                        <button class="btn btn-primary" id="updateStatusBtn">Update Status</button>
                    </div>
                </div>

                <!-- Status History Tab -->
                <div class="tab-content" id="history-tab">
                    <div class="status-history">
                        <div class="status-timeline" id="statusTimeline">
                            <!-- Status history will be loaded here -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Global variables
        let currentApplicationId = null;
        let authToken = null;
        let currentAdmin = null;

        // Initialize dashboard
        document.addEventListener('DOMContentLoaded', function () {
            console.log('🚀 Dashboard DOM loaded');
            initializeDashboard();
        });

        // Main dashboard initialization
        async function initializeDashboard() {
            console.log('🔐 Initializing dashboard...');

            // Get token from multiple sources
            authToken = getTokenFromStorage();

            console.log('🔑 Token found:', authToken ? 'Yes' : 'No');

            if (!authToken) {
                console.error('❌ No authentication token found');
                redirectToLogin('Please login to access the dashboard');
                return;
            }

            try {
                console.log('👤 Verifying token and loading profile...');
                await verifyTokenAndLoadProfile();

                console.log('📊 Loading dashboard data...');
                await loadDashboardData();

                console.log('🎯 Setting up event listeners...');
                setupEventListeners();

                console.log('✅ Dashboard initialized successfully');

            } catch (error) {
                console.error('❌ Dashboard initialization failed:', error);

                if (error.message.includes('token') || error.message.includes('unauthorized') || error.message.includes('401')) {
                    redirectToLogin('Session expired. Please login again.');
                } else {
                    showError('Failed to initialize dashboard: ' + error.message);
                }
            }
        }

        // Get token from all possible storage locations
        function getTokenFromStorage() {
            // 1. Check URL parameters first (for redirects)
            const urlParams = new URLSearchParams(window.location.search);
            const urlToken = urlParams.get('token');
            if (urlToken) {
                console.log('✅ Token from URL');
                // Clean URL after getting token
                window.history.replaceState({}, document.title, window.location.pathname);
                return urlToken;
            }

            // 2. Check localStorage
            const localToken = localStorage.getItem('adminToken');
            if (localToken) {
                console.log('✅ Token from localStorage');
                return localToken;
            }

            // 3. Check sessionStorage
            const sessionToken = sessionStorage.getItem('adminToken');
            if (sessionToken) {
                console.log('✅ Token from sessionStorage');
                return sessionToken;
            }

            console.log('❌ No token found in any storage');
            return null;
        }

        // Verify token and load admin profile
        async function verifyTokenAndLoadProfile() {
            try {
                console.log('🔍 Making profile request...');

                const response = await fetch('/api/auth/profile', {
                    method: 'GET',
                    headers: {
                        'Authorization': `Bearer ${authToken}`,
                        'Content-Type': 'application/json'
                    },
                    credentials: 'include'
                });

                console.log('📨 Profile response status:', response.status);

                if (response.status === 401) {
                    throw new Error('Token invalid or expired');
                }

                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                }

                const data = await response.json();
                console.log('👤 Profile data received:', data);

                if (data.success && data.admin) {
                    currentAdmin = data.admin;
                    updateUserInfo(currentAdmin);
                    console.log('✅ Profile loaded successfully');
                } else {
                    throw new Error(data.message || 'Invalid profile response');
                }
            } catch (error) {
                console.error('❌ Profile loading failed:', error);
                throw new Error('Authentication failed: ' + error.message);
            }
        }

        // Update user information in header
        function updateUserInfo(admin) {
            document.getElementById('userName').textContent = admin.name;
            const avatar = document.getElementById('userAvatar');
            avatar.textContent = admin.name.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2);
            avatar.title = admin.name;
        }

        // Load dashboard data
        async function loadDashboardData() {
            try {
                await Promise.all([
                    loadApplicationStats(),
                    loadApplications()
                ]);
            } catch (error) {
                console.error('❌ Dashboard data loading failed:', error);
                throw error;
            }
        }

        // Load application statistics
        async function loadApplicationStats() {
            try {
                console.log('📈 Loading application statistics...');

                const response = await fetch('/api/applications/stats', {
                    method: 'GET',
                    headers: {
                        'Authorization': `Bearer ${authToken}`,
                        'Content-Type': 'application/json'
                    }
                });

                console.log('📊 Stats response status:', response.status);

                if (response.status === 401) {
                    throw new Error('Unauthorized - Invalid token');
                }

                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}: Failed to load statistics`);
                }

                const data = await response.json();
                console.log('📈 Stats data:', data);

                if (data.success) {
                    updateStats(data.stats);
                    console.log('✅ Statistics loaded successfully');
                } else {
                    throw new Error(data.message || 'Failed to load statistics');
                }
            } catch (error) {
                console.error('❌ Statistics loading failed:', error);
                throw error;
            }
        }

        // Update statistics cards
        function updateStats(stats) {
            const submitted = stats.submitted || 0;
            const verified = stats.document_verified || 0;
            const background = stats.background_check || 0;
            const approved = stats.approved || 0;

            document.getElementById('submittedCount').textContent = submitted;
            document.getElementById('verifiedCount').textContent = verified;
            document.getElementById('backgroundCount').textContent = background;
            document.getElementById('approvedCount').textContent = approved;

            console.log(`📊 Stats updated: ${submitted} submitted, ${verified} verified, ${background} background, ${approved} approved`);
        }

        // Load applications list
        async function loadApplications() {
            try {
                console.log('📋 Loading applications list...');

                const response = await fetch('/api/applications/all', {
                    method: 'GET',
                    headers: {
                        'Authorization': `Bearer ${authToken}`,
                        'Content-Type': 'application/json'
                    }
                });

                console.log('📨 Applications response status:', response.status);

                if (response.status === 401) {
                    throw new Error('Unauthorized - Invalid token');
                }

                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}: Failed to load applications`);
                }

                const data = await response.json();
                console.log('📋 Applications data received, count:', data.applications ? data.applications.length : 0);

                if (data.success) {
                    renderApplicationsTable(data.applications);
                    console.log('✅ Applications loaded successfully');
                } else {
                    throw new Error(data.message || 'Failed to load applications');
                }
            } catch (error) {
                console.error('❌ Applications loading failed:', error);
                throw error;
            }
        }

        // Render applications table
        function renderApplicationsTable(applications) {
            const tbody = document.getElementById('applicationsTableBody');

            if (!applications || applications.length === 0) {
                tbody.innerHTML = '<tr><td colspan="8" style="text-align: center; padding: 40px; color: var(--gray);">No applications found</td></tr>';
                return;
            }

            tbody.innerHTML = applications.map(app => `
        <tr>
            <td><strong>${app.tracking_id || 'N/A'}</strong></td>
            <td>${escapeHtml(app.full_name)}</td>
            <td>${escapeHtml(app.email)}</td>
            <td>${escapeHtml(app.phone)}</td>
            <td>${app.driving_experience || 0} years</td>
            <td>${app.license_type || 'N/A'}</td>
            <td><span class="status-badge status-${app.status}">${formatStatus(app.status)}</span></td>
            <td>
                <button class="action-btn view-details" data-id="${app.id}" title="View application details">
                    <i class="fas fa-eye"></i> View
                </button>
            </td>
        </tr>
    `).join('');

            // Attach event listeners to view buttons
            document.querySelectorAll('.view-details').forEach(button => {
                button.addEventListener('click', function () {
                    const appId = this.getAttribute('data-id');
                    console.log('👁️ Viewing application details:', appId);
                    openApplicationDetails(appId);
                });
            });

            console.log(`✅ Rendered ${applications.length} applications`);
        }

        // Format status for display
        function formatStatus(status) {
            const statusMap = {
                'submitted': 'Submitted',
                'document_verified': 'Verified',
                'background_check': 'Background Check',
                'interview_scheduled': 'Interview',
                'approved': 'Approved',
                'rejected': 'Rejected'
            };
            return statusMap[status] || status;
        }

        // Escape HTML to prevent XSS
        function escapeHtml(unsafe) {
            if (unsafe === null || unsafe === undefined) return '';
            return unsafe
                .toString()
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        // Open application details modal
        async function openApplicationDetails(applicationId) {
            if (!applicationId) {
                showError('Invalid application ID');
                return;
            }

            currentApplicationId = applicationId;

            try {
                console.log('📄 Loading application details:', applicationId);

                const response = await fetch(`/api/applications/${applicationId}`, {
                    method: 'GET',
                    headers: {
                        'Authorization': `Bearer ${authToken}`,
                        'Content-Type': 'application/json'
                    }
                });

                console.log('📨 Application details response status:', response.status);

                if (response.status === 401) {
                    throw new Error('Unauthorized - Invalid token');
                }

                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}: Failed to load application details`);
                }

                const data = await response.json();
                console.log('📄 Application details received:', data);

                if (data.success) {
                    populateApplicationDetails(data.application);
                    openModal();
                    console.log('✅ Application details loaded successfully');
                } else {
                    throw new Error(data.message || 'Failed to load application details');
                }
            } catch (error) {
                console.error('❌ Application details loading failed:', error);
                showError('Failed to load application details: ' + error.message);
            }
        }

        // Populate application details in modal
        function populateApplicationDetails(application) {
            if (!application) {
                showError('No application data received');
                return;
            }

            // Basic info
            document.getElementById('modal-app-id').textContent = application.tracking_id || 'N/A';
            document.getElementById('detail-name').textContent = application.full_name || 'N/A';
            document.getElementById('detail-email').textContent = application.email || 'N/A';
            document.getElementById('detail-phone').textContent = application.phone || 'N/A';
            document.getElementById('detail-dob').textContent = application.formatted_dob || application.dob || 'N/A';
            document.getElementById('detail-address').textContent = application.address || 'N/A';
            document.getElementById('detail-experience').textContent = `${application.driving_experience || 0} years`;
            document.getElementById('detail-license').textContent = application.license_type || 'N/A';
            document.getElementById('detail-vehicle').textContent = application.vehicle_type || 'Not specified';
            document.getElementById('detail-availability').textContent = formatAvailability(application.availability);
            document.getElementById('detail-locations').textContent = formatLocations(application.preferred_locations);
            document.getElementById('detail-additional').textContent = application.additional_info || 'No additional information provided';

            // Populate other sections
            populateDocuments(application);
            populateStatusHistory(application.status_history || []);

            // Set current status in dropdown
            if (application.status) {
                document.getElementById('status-select').value = application.status;
            }
        }

        // Format availability for display
        function formatAvailability(availability) {
            const availabilityMap = {
                'immediate': 'Immediate',
                '1week': '1 Week',
                '2weeks': '2 Weeks',
                '1month': '1 Month'
            };
            return availabilityMap[availability] || availability || 'Not specified';
        }

        // Format locations for display
        function formatLocations(locations) {
            if (!locations) return 'Not specified';

            if (Array.isArray(locations)) {
                return locations.join(', ');
            }

            if (typeof locations === 'string') {
                try {
                    const parsed = JSON.parse(locations);
                    return Array.isArray(parsed) ? parsed.join(', ') : locations;
                } catch {
                    return locations;
                }
            }

            return 'Not specified';
        }

        // Populate documents section - FIXED VERSION
        function populateDocuments(application) {
            const documentsGrid = document.getElementById('documentsGrid');
            const documents = [];

            if (application.license_filename && application.license_filepath) {
                documents.push({
                    name: "Driver's License",
                    filename: application.license_filename,
                    filepath: application.license_filepath,
                    icon: 'fa-id-card',
                    type: 'license'
                });
            }

            if (application.photo_filename && application.photo_filepath) {
                documents.push({
                    name: "Passport Photo",
                    filename: application.photo_filename,
                    filepath: application.photo_filepath,
                    icon: 'fa-user',
                    type: 'photo'
                });
            }

            if (application.address_filename && application.address_filepath) {
                documents.push({
                    name: "Address Proof",
                    filename: application.address_filename,
                    filepath: application.address_filepath,
                    icon: 'fa-file-invoice',
                    type: 'address'
                });
            }

            if (documents.length === 0) {
                documentsGrid.innerHTML = '<p style="color: var(--gray); text-align: center; padding: 20px;">No documents uploaded</p>';
                return;
            }

            documentsGrid.innerHTML = documents.map(doc => `
        <div class="document-card">
            <div class="document-preview" id="preview-${doc.type}">
                <i class="fas ${doc.icon}"></i>
                <div class="document-loading">Loading preview...</div>
                <img src="" alt="${doc.name}" onload="onDocumentImageLoad('${doc.type}')" onerror="onDocumentImageError('${doc.type}')">
            </div>
            <div class="document-info">
                <div class="document-name">${doc.name}</div>
                <div class="document-actions">
                    <button class="btn btn-primary" onclick="viewDocument('${doc.filepath}')">
                        <i class="fas fa-eye"></i> View
                    </button>
                    <button class="btn btn-outline" onclick="downloadDocument('${doc.filepath}', '${doc.filename}')">
                        <i class="fas fa-download"></i> Download
                    </button>
                </div>
            </div>
        </div>
    `).join('');

            // Load images after DOM is updated
            setTimeout(() => {
                documents.forEach(doc => {
                    loadDocumentPreview(doc.filepath, doc.type);
                });
            }, 100);

            console.log(`✅ Loaded ${documents.length} documents`);
        }

       // FIXED: Load document preview image
function loadDocumentPreview(filepath, type) {
    const previewElement = document.getElementById(`preview-${type}`);
    const imgElement = previewElement.querySelector('img');
    
    if (!filepath) {
        console.warn(`No filepath for document type: ${type}`);
        return;
    }
    
    console.log(`🔍 Original filepath: ${filepath}`);
    
    // FIX: Handle different path formats
    let fixedPath = filepath;
    
    // Case 1: If path has backslashes (Windows format)
    if (filepath.includes('\\')) {
        fixedPath = filepath.replace(/\\/g, '/');
    }
    
    // Case 2: If path is missing slash between uploads and filename
    if (fixedPath.includes('uploads') && !fixedPath.includes('uploads/')) {
        fixedPath = fixedPath.replace('uploads', 'uploads/');
    }
    
    // Case 3: If it's just a filename without uploads folder
    if (!fixedPath.includes('uploads/') && !fixedPath.includes('/')) {
        fixedPath = 'uploads/' + fixedPath;
    }
    
    // Ensure proper URL format
    let fullPath = fixedPath;
    if (!fixedPath.startsWith('http') && !fixedPath.startsWith('/')) {
        fullPath = '/' + fixedPath;
    }
    if (!fixedPath.startsWith('http')) {
        fullPath = window.location.origin + fullPath;
    }
    
    console.log(`🖼️ Loading document preview: ${fullPath}`);
    
    imgElement.src = fullPath;
    imgElement.alt = `Document ${type}`;
}

        // Handle document image load
        function onDocumentImageLoad(type) {
            const previewElement = document.getElementById(`preview-${type}`);
            const loadingElement = previewElement.querySelector('.document-loading');

            previewElement.classList.add('has-image');
            if (loadingElement) {
                loadingElement.style.display = 'none';
            }

            console.log(`✅ Document image loaded: ${type}`);
        }

        // Handle document image error
        function onDocumentImageError(type) {
            const previewElement = document.getElementById(`preview-${type}`);
            const loadingElement = previewElement.querySelector('.document-loading');
            const imgElement = previewElement.querySelector('img');

            // Hide the broken image
            imgElement.style.display = 'none';

            // Show error message
            if (loadingElement) {
                loadingElement.textContent = 'Preview not available';
                loadingElement.style.color = 'var(--danger)';
            }

            console.warn(`❌ Failed to load document image: ${type}`);
        }

        // Populate status history
        function populateStatusHistory(history) {
            const timeline = document.getElementById('statusTimeline');

            if (!history || history.length === 0) {
                timeline.innerHTML = '<p style="color: var(--gray); text-align: center; padding: 20px;">No status history available</p>';
                return;
            }

            // Sort history by date (newest first)
            const sortedHistory = [...history].sort((a, b) => new Date(b.date || b.created_at) - new Date(a.date || a.created_at));

            timeline.innerHTML = sortedHistory.map(item => `
        <div class="status-item ${item.status === 'approved' ? 'completed' : item.status === 'rejected' ? 'rejected' : ''}">
            <div class="status-date">${formatDate(item.date || item.created_at)}</div>
            <div class="status-title"><strong>${formatStatus(item.status)}</strong></div>
            <div class="status-notes">${escapeHtml(item.notes || 'No notes provided')}</div>
        </div>
    `).join('');

            console.log(`✅ Loaded ${history.length} status history items`);
        }

        // Format date for display
        function formatDate(dateString) {
            if (!dateString) return 'Unknown date';

            try {
                const date = new Date(dateString);
                return date.toLocaleDateString('en-IN', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                });
            } catch {
                return dateString;
            }
        }

        // FIXED: View document
function viewDocument(filepath) {
    if (!filepath) {
        showError('No file path provided');
        return;
    }
    
    console.log(`🔍 Original view path: ${filepath}`);
    
    // Apply the same path fixes
    let fixedPath = filepath;
    if (filepath.includes('\\')) {
        fixedPath = filepath.replace(/\\/g, '/');
    }
    if (fixedPath.includes('uploads') && !fixedPath.includes('uploads/')) {
        fixedPath = fixedPath.replace('uploads', 'uploads/');
    }
    if (!fixedPath.includes('uploads/') && !fixedPath.includes('/')) {
        fixedPath = 'uploads/' + fixedPath;
    }
    
    let fullPath = fixedPath;
    if (!fixedPath.startsWith('http') && !fixedPath.startsWith('/')) {
        fullPath = '/' + fixedPath;
    }
    if (!fixedPath.startsWith('http')) {
        fullPath = window.location.origin + fullPath;
    }
    
    console.log(`👀 Opening document: ${fullPath}`);
    window.open(fullPath, '_blank', 'noopener,noreferrer');
}

// FIXED: Download document
function downloadDocument(filepath, filename) {
    if (!filepath) {
        showError('No file path provided');
        return;
    }
    
    console.log(`🔍 Original download path: ${filepath}`);
    
    // Apply the same path fixes
    let fixedPath = filepath;
    if (filepath.includes('\\')) {
        fixedPath = filepath.replace(/\\/g, '/');
    }
    if (fixedPath.includes('uploads') && !fixedPath.includes('uploads/')) {
        fixedPath = fixedPath.replace('uploads', 'uploads/');
    }
    if (!fixedPath.includes('uploads/') && !fixedPath.includes('/')) {
        fixedPath = 'uploads/' + fixedPath;
    }
    
    let fullPath = fixedPath;
    if (!fixedPath.startsWith('http') && !fixedPath.startsWith('/')) {
        fullPath = '/' + fixedPath;
    }
    if (!fixedPath.startsWith('http')) {
        fullPath = window.location.origin + fullPath;
    }
    
    console.log(`📥 Downloading document: ${fullPath}`);
    
    const link = document.createElement('a');
    link.href = fullPath;
    link.download = filename || 'document';
    link.target = '_blank';
    link.rel = 'noopener noreferrer';
    
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
}

        // Update application status
        document.getElementById('updateStatusBtn').addEventListener('click', async function () {
            const status = document.getElementById('status-select').value;
            const notes = document.getElementById('status-notes').value;

            if (!currentApplicationId) {
                showError('No application selected');
                return;
            }

            if (!status) {
                showError('Please select a status');
                return;
            }

            const updateBtn = this;
            const originalText = updateBtn.innerHTML;

            try {
                // Show loading state
                updateBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Updating...';
                updateBtn.disabled = true;

                console.log('🔄 Updating application status:', { applicationId: currentApplicationId, status, notes });

                const response = await fetch(`/api/applications/${currentApplicationId}/status`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${authToken}`
                    },
                    body: JSON.stringify({
                        status: status,
                        notes: notes
                    })
                });

                console.log('📨 Status update response status:', response.status);

                if (response.status === 401) {
                    throw new Error('Unauthorized - Invalid token');
                }

                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}: Failed to update status`);
                }

                const data = await response.json();
                console.log('✅ Status update response:', data);

                if (data.success) {
                    // Reload applications and close modal
                    await loadApplications();
                    await loadApplicationStats(); // Refresh stats too
                    closeModal();
                    showSuccess('Status updated successfully');
                } else {
                    throw new Error(data.message || 'Failed to update status');
                }
            } catch (error) {
                console.error('❌ Status update failed:', error);
                showError('Failed to update application status: ' + error.message);
            } finally {
                // Reset button state
                updateBtn.innerHTML = originalText;
                updateBtn.disabled = false;
            }
        });

        // Setup event listeners
        function setupEventListeners() {
            console.log('🎯 Setting up event listeners...');

            // Logout button
            document.getElementById('logoutBtn').addEventListener('click', logout);

            // Filter changes
            document.getElementById('statusFilter').addEventListener('change', applyFilters);
            document.getElementById('sortFilter').addEventListener('change', applyFilters);

            // Modal functionality
            setupModalEvents();

            console.log('✅ Event listeners setup complete');
        }

        // Apply filters to applications
        function applyFilters() {
            console.log('🔍 Applying filters...');
            loadApplications(); // Reload with current filters
        }

        // Modal functionality
        function setupModalEvents() {
            const modal = document.getElementById('applicationModal');
            const closeModal = document.querySelector('.close-modal');

            // Tab functionality
            document.querySelectorAll('.tab').forEach(tab => {
                tab.addEventListener('click', function () {
                    const tabId = this.getAttribute('data-tab');
                    console.log('📑 Switching to tab:', tabId);

                    // Remove active class from all tabs and contents
                    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
                    document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));

                    // Add active class to clicked tab
                    this.classList.add('active');

                    // Show corresponding content
                    document.getElementById(`${tabId}-tab`).classList.add('active');
                });
            });

            closeModal.addEventListener('click', closeModalFunc);

            // Close modal when clicking outside
            modal.addEventListener('click', (e) => {
                if (e.target === modal) {
                    closeModalFunc();
                }
            });

            console.log('✅ Modal events setup complete');
        }

        function openModal() {
            const modal = document.getElementById('applicationModal');
            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
            console.log('📂 Modal opened');
        }

        function closeModalFunc() {
            const modal = document.getElementById('applicationModal');
            modal.classList.remove('active');
            document.body.style.overflow = 'auto';
            currentApplicationId = null;

            // Reset form
            document.getElementById('status-notes').value = '';

            console.log('📂 Modal closed');
        }

        // Logout function
        function logout() {
            console.log('🚪 Logging out...');

            // Clear all storage
            localStorage.removeItem('adminToken');
            localStorage.removeItem('adminData');
            sessionStorage.removeItem('adminToken');
            sessionStorage.removeItem('adminData');

            // Clear global variables
            authToken = null;
            currentAdmin = null;
            currentApplicationId = null;

            console.log('✅ Storage cleared, redirecting to login...');

            // Redirect to login
            redirectToLogin('You have been logged out successfully');
        }

        // Redirect to login page
        function redirectToLogin(message = '') {
            const params = new URLSearchParams();
            if (message) {
                params.set('message', encodeURIComponent(message));
            }
            window.location.href = `/login?${params.toString()}`;
        }

        // Show error message
        function showError(message) {
            console.error('❌ Error:', message);
            const alert = document.getElementById('errorAlert');
            const messageElement = document.getElementById('errorMessage');

            if (alert && messageElement) {
                messageElement.textContent = message;
                alert.style.display = 'block';

                setTimeout(() => {
                    alert.style.display = 'none';
                }, 5000);
            } else {
                alert('Error: ' + message);
            }
        }

        // Show success message
        function showSuccess(message) {
            console.log('✅ Success:', message);
            // You can implement a success toast/notification here
            // For now, we'll just log to console
        }

        // Global functions for document actions
        window.viewDocument = viewDocument;
        window.downloadDocument = downloadDocument;
        window.onDocumentImageLoad = onDocumentImageLoad;
        window.onDocumentImageError = onDocumentImageError;
    </script>
