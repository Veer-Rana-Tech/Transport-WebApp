<% 
let aboutContent = `
    <!-- About Hero Section -->
    <section class="about-hero" id="about">
        <div class="container">
            <div class="about-hero-content">
                <h1 class="animate__animated animate__fadeInDown">About Ek Transporter</h1>
                <p class="animate__animated animate__fadeInUp">Driving India's growth with reliable, professional transporter services since 2010. Connecting businesses and communities across the nation.</p>
            </div>
        </div>
    </section>

    <!-- Company Overview -->
    <section class="section">
        <div class="container">
            <div class="about-content">
                <div class="about-text">
                    <h2>Our Journey</h2>
                    <p>Founded in 2010, Ek Transporter has grown from a small regional carrier to one of India's most trusted transporter companies. With over a decade of experience, we've built a reputation for reliability, safety, and excellence in logistics and transporter ation services.</p>
                    
                    <p>Our network spans across all 28 states of India, connecting major cities, industrial hubs, and rural areas. We pride ourselves on being more than just a transporter company - we're partners in our clients' success and enablers of economic growth.</p>
                    
                    <div class="mission-vision">
                        <div class="mv-item">
                            <div class="mv-icon">
                                <i class="fas fa-bullseye"></i>
                            </div>
                            <h3>Our Mission</h3>
                            <p>To provide safe, efficient, and reliable transportation solutions that exceed customer expectations while creating sustainable value for our employees and stakeholders.</p>
                        </div>
                        <div class="mv-item">
                            <div class="mv-icon">
                                <i class="fas fa-eye"></i>
                            </div>
                            <h3>Our Vision</h3>
                            <p>To be India's most trusted and innovative transporter company, setting new standards in safety, technology, and customer service in the logistics industry.</p>
                        </div>
                    </div>
                </div>
                <div class="about-image">
                    <div class="image-placeholder">
                        <i class="fas fa-truck-moving"></i>
                        <p>Ek Transporter Fleet</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Values Section -->
    <section class="section values-section">
        <div class="container">
            <h2 class="section-title">Our Values</h2>
            <div class="values-grid">
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <h3>Safety First</h3>
                    <p>We prioritize the safety of our drivers, cargo, and the public above all else. Regular training and strict safety protocols ensure secure operations.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <h3>Teamwork</h3>
                    <p>We believe in collaborative success. Our drivers, support staff, and management work together as one cohesive team.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-handshake"></i>
                    </div>
                    <h3>Integrity</h3>
                    <p>Honest business practices, transparent operations, and ethical conduct form the foundation of everything we do.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-tachometer-alt"></i>
                    </div>
                    <h3>Excellence</h3>
                    <p>We strive for excellence in every aspect of our service, from driver training to customer support and delivery timelines.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-heart"></i>
                    </div>
                    <h3>Care</h3>
                    <p>We care for our employees, customers, and the environment. Sustainable practices and employee welfare are key priorities.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-lightbulb"></i>
                    </div>
                    <h3>Innovation</h3>
                    <p>Embracing technology and innovative solutions to improve efficiency, tracking, and overall service quality.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Leadership Team -->
    <section class="section team-section">
        <div class="container">
            <h2 class="section-title">Leadership Team</h2>
            <div class="team-grid">
                <div class="team-member">
                    <div class="member-photo">
                        <i class="fas fa-user-tie"></i>
                    </div>
                    <h3>Rahul Sharma</h3>
                    <span class="member-role">Founder & CEO</span>
                    <p>With over 20 years in the transporter industry, Rahul founded Ek Transporter with a vision to revolutionize logistics in India.</p>
                </div>
                <div class="team-member">
                    <div class="member-photo">
                        <i class="fas fa-user-tie"></i>
                    </div>
                    <h3>Priya Verma</h3>
                    <span class="member-role">Operations Director</span>
                    <p>Priya oversees all operational aspects, ensuring smooth logistics and efficient service delivery across the network.</p>
                </div>
                <div class="team-member">
                    <div class="member-photo">
                        <i class="fas fa-user-tie"></i>
                    </div>
                    <h3>Arjun Mehta</h3>
                    <span class="member-role">HR & Driver Relations</span>
                    <p>Arjun manages our driver community, focusing on welfare, training, and creating a supportive work environment.</p>
                </div>
                <div class="team-member">
                    <div class="member-photo">
                        <i class="fas fa-user-tie"></i>
                    </div>
                    <h3>Sanjay Kapoor</h3>
                    <span class="member-role">Safety & Compliance Head</span>
                    <p>Sanjay ensures all operations meet regulatory standards and maintains our impeccable safety record.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Company Achievements -->
    <section class="section achievements-section">
        <div class="container">
            <h2 class="section-title">Our Achievements</h2>
            <div class="achievements">
                <div class="achievement-item">
                    <div class="achievement-icon">
                        <i class="fas fa-award"></i>
                    </div>
                    <h3>National Transporter Excellence Award 2022</h3>
                    <p>Recognized for outstanding service and innovation in logistics</p>
                </div>
                <div class="achievement-item">
                    <div class="achievement-icon">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <h3>ISO 9001:2015 Certified</h3>
                    <p>Quality management system certification for operational excellence</p>
                </div>
                <div class="achievement-item">
                    <div class="achievement-icon">
                        <i class="fas fa-trophy"></i>
                    </div>
                    <h3>Best Employer Award 2023</h3>
                    <p>Acknowledged for exceptional employee welfare and work culture</p>
                </div>
                <div class="achievement-item">
                    <div class="achievement-icon">
                        <i class="fas fa-leaf"></i>
                    </div>
                    <h3>Green Transporter Initiative</h3>
                    <p>Leading the industry in sustainable and eco-friendly transporter solutions</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Fleet Information -->
    <section class="section fleet-section">
        <div class="container">
            <h2 class="section-title">Our Fleet</h2>
            <div class="fleet-info">
                <div class="fleet-stats">
                    <div class="fleet-stat">
                        <div class="stat-number">1500+</div>
                        <div class="stat-label">Vehicles</div>
                    </div>
                    <div class="fleet-stat">
                        <div class="stat-number">28</div>
                        <div class="stat-label">States Covered</div>
                    </div>
                    <div class="fleet-stat">
                        <div class="stat-number">500+</div>
                        <div class="stat-label">Cities Connected</div>
                    </div>
                    <div class="fleet-stat">
                        <div class="stat-number">99.2%</div>
                        <div class="stat-label">On-time Delivery</div>
                    </div>
                </div>
                
                <div class="fleet-types">
                    <h3>Vehicle Types</h3>
                    <div class="vehicle-types">
                        <div class="vehicle-type">
                            <i class="fas fa-truck"></i>
                            <span>Light Commercial Vehicles</span>
                        </div>
                        <div class="vehicle-type">
                            <i class="fas fa-truck-moving"></i>
                            <span>Heavy Trucks</span>
                        </div>
                        <div class="vehicle-type">
                            <i class="fas fa-bus"></i>
                            <span>Passenger Buses</span>
                        </div>
                        <div class="vehicle-type">
                            <i class="fas fa-truck-loading"></i>
                            <span>Container Carriers</span>
                        </div>
                        <div class="vehicle-type">
                            <i class="fas fa-truck-pickup"></i>
                            <span>Specialized Vehicles</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CSR Section -->
    <section class="section csr-section">
        <div class="container">
            <h2 class="section-title">Corporate Social Responsibility</h2>
            <div class="csr-content">
                <div class="csr-initiatives">
                    <div class="csr-item">
                        <h3><i class="fas fa-graduation-cap"></i> Driver Education</h3>
                        <p>We provide free training and skill development programs for aspiring commercial drivers from underprivileged backgrounds.</p>
                    </div>
                    <div class="csr-item">
                        <h3><i class="fas fa-tree"></i> Environmental Initiatives</h3>
                        <p>Regular tree plantation drives and investment in eco-friendly vehicles to reduce our carbon footprint.</p>
                    </div>
                    <div class="csr-item">
                        <h3><i class="fas fa-hand-holding-heart"></i> Community Support</h3>
                        <p>Supporting local communities through disaster relief transporter services and community development programs.</p>
                    </div>
                    <div class="csr-item">
                        <h3><i class="fas fa-road"></i> Road Safety Awareness</h3>
                        <p>Conducting road safety workshops and awareness campaigns in schools and communities across India.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact CTA -->
    <section class="section contact-cta">
        <div class="container">
            <div class="cta-content">
                <h2>Join the Ek Transporter Family</h2>
                <p>Become part of our growing team and help us drive India forward</p>
                <div class="cta-buttons">
                    <a href="/" class="btn">View Job Opportunities</a>
                    <a href="#contact" class="btn-c">Contact Us</a>
                </div>
            </div>
        </div>
    </section>
`;
%>

<%- include('../base', {
    title: 'About Us - Ek Transporter',
    page: 'about',
    content: aboutContent
}) %>