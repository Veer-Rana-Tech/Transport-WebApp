<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Ek Transport - India's leading professional driver job portal with nationwide opportunities and competitive benefits.">
    <meta name="keywords" content="driver jobs, transport company, truck driver, professional driver, India jobs">
    <title><%= typeof title !== 'undefined' ? title : 'Ek Transport - Professional Driver Job Portal' %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
   
    <!-- Header Section -->
<header>
    <div class="container header-content">
        <div class="logo">
            <i class="fas fa-truck-moving logo-icon"></i>
            <span class="logo-text">Ek Transporter</span>
        </div>
        
        <nav id="mainNav">
            <ul>
                <li><a href="#home" class="<%= typeof page !== 'undefined' && page === 'home' ? 'active' : '' %>">Home</a></li>
                <li><a href="#features">Why Choose Us</a></li>
                <li><a href="#apply">Apply Now</a></li>
                <li><a href="#tracking">Track Application</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
        </nav>
        
        <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Toggle navigation menu">
            <i class="fas fa-bars"></i>
        </button>
    </div>
</header>

    <!-- Main Content Block -->
    <main id="main-content">
        <%- typeof content !== 'undefined' ? content : '' %>
    </main>

    <!-- Footer -->
    <footer id="contact">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>Ek Transporter</h3>
                    <p>international transport company providing employment opportunities to thousands of professional drivers across the country with competitive packages and growth opportunities.</p>
                    <div class="social-links">
                        <a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
                        <a href="#" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>
                <div class="footer-section">
                    <h3>Quick Links</h3>
                    <ul>
                        <li><a href="#home" class="<%= typeof page !== 'undefined' && page === 'home' ? 'active' : '' %>">Home</a></li>
                        <li><a href="#tracking"> Track Application</a></li>
                        <li><a href="/carrer" class="<%= page === 'carrer' ? 'active' : '' %>">Carrier</a></li>
                        <li><a href="/about" class="<%= page === 'about' ? 'active' : '' %>">About Us</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h3>Contact Us</h3>
                    <ul>
                        <li><a href="mailto:info@ektransport.com"><i class="fas fa-envelope"></i> support@ektransporter.com</a></li>
                        <li><a href="#"><i class="fas fa-map-marker-alt"></i> Corporate Office: New Delhi, India</a></li>
                        <li><a href="#"><i class="fas fa-clock"></i> Mon-Sat: 9:00 AM - 6:00 PM</a></li>
                    </ul>
                </div>
                
            </div>
            <div class="copyright">
                <p>&copy; 2023-25 Ek Transporter. All Rights Reserved. </p>
            </div>
        </div>
    </footer>

    <!-- Loading Spinner -->
    <div id="loading-spinner" class="hidden">
        <div class="spinner"></div>
    </div>

    <script src="/js/script.js"></script>
</body>
</html>